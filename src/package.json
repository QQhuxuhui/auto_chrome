{
  "name": "antigravity-batch-auth",
  "version": "10.0.0",
  "description": "Antigravity Batch OAuth Authorization Tool v10",
  "main": "auth.js",
  "scripts": {
    "start": "node auth.js",
    "start:verbose": "node auth.js --verbose",
    "start:test": "node auth.js --test 2 --verbose",
    "server": "node server.js",
    "db:init": "node ../scripts/init-db.js",
    "db:migrate-txt": "node ../scripts/migrate-txt.js",
